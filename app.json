{
  "expo": {
    "name": "AttendEase",
    "slug": "atulsahu",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "dark",
    "scheme": "attendease",
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.attendease.app"
    },
    "android": {
      "package": "com.attendease.app",
      "adaptiveIcon": {
        "backgroundColor": "#0F172A"
      }
    },
    "web": {
      "bundler": "metro",
      "output": "static"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {
        "origin": false
      },
      "eas": {
        "projectId": "8e461186-dc55-4a40-96ab-4cdcf0199213"
      }
    },
    "owner": "ofcatul"
  }
}
